# Environment Configuration
ENVIRONMENT=development  # Options: development, testing, production

# Application Version (optional, falls back to pyproject.toml or 1.0.0)
# VERSION=1.0.0

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Dev Token (Only works in development and testing environments)
# This token can be used for quick testing without needing to login
# It will be automatically disabled in production
DEV_TOKEN=dev-token-12345

# Supabase Configuration
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-key

# API Configuration
API_KEY=ss
PORT=8090

# Other configurations
COMMIT_SHA=unknown
